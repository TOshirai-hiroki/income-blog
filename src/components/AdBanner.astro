---
interface Props {
	position?: 'top' | 'middle' | 'bottom' | 'sidebar';
}

const { position = 'middle' } = Astro.props;
---

<div class={`ad-banner ad-${position} my-6 text-center`} data-ad-position={position}>
	<ins class="adsbygoogle"
		style="display:block"
		data-ad-client="ca-pub-2016529992214438"
		data-ad-slot="1257638394"
		data-ad-format="auto"
		data-full-width-responsive="true"></ins>
	<script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>
