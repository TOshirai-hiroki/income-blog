---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="bg-white shadow-sm sticky top-0 z-50">
	<nav class="max-w-[960px] mx-auto flex items-center justify-between px-4 py-3">
		<h2 class="m-0 text-lg font-bold">
			<a href="/" class="text-blue-600 no-underline hover:no-underline">{SITE_TITLE}</a>
		</h2>
		<div class="flex gap-4 text-sm">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/blog">記事一覧</HeaderLink>
			<HeaderLink href="/about">サイト概要</HeaderLink>
		</div>
	</nav>
</header>
