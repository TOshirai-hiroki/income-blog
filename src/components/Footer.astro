---
const today = new Date();
---

<footer class="footer-gradient text-center py-10 mt-12 text-sm">
	<div class="max-w-[960px] mx-auto px-4">
		<div class="flex items-center justify-center gap-2 mb-4">
			<img src="/images/logo-icon.png" alt="" class="w-6 h-6 rounded" />
			<span class="font-bold text-blue-200 text-base">AI比較ラボ</span>
		</div>
		<div class="flex justify-center gap-6 mb-4">
			<a href="/about" class="text-blue-100/70 hover:text-blue-100 no-underline transition">サイト概要</a>
			<a href="/privacy" class="text-blue-100/70 hover:text-blue-100 no-underline transition">プライバシーポリシー</a>
			<a href="/terms" class="text-blue-100/70 hover:text-blue-100 no-underline transition">利用規約</a>
			<a href="/contact" class="text-blue-100/70 hover:text-blue-100 no-underline transition">お問い合わせ</a>
		</div>
		<p class="m-0 text-blue-100/50">&copy; {today.getFullYear()} AI比較ラボ All rights reserved.</p>
	</div>
</footer>

<style>
	.footer-gradient {
		background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
	}
</style>
